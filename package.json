{
  "name": "user-service",
  "engines": {
    "node": "24.15"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "start:dev": "tsx watch --tsconfig tsconfig.json src/server.ts",
    "test": "vitest run && dependency-cruiser src --config .dependency-cruiser.js",
    "test:unit": "vitest run src/test/unit",
    "test:integration": "vitest run src/test/integration",
    "test:component": "vitest run src/test/component",
    "test:arch": "depcruise src --config .dependency-cruiser.js",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,js}\" --ignore-unknown",
    "format:check": "prettier --check \"src/**/*.{ts,js}\" --ignore-unknown",
    "docs": "typedoc --entryPointStrategy expand ./src --plugin typedoc-github-theme",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint",
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.75.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.217.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.30.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.217.0",
    "bcryptjs": "^3.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.0.0",
    "ms": "^2.1.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-opentelemetry-transport": "^3.0.0",
    "reflect-metadata": "^0.2.2",
    "uuid": "^14.0.0",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.3.0",
    "@types/supertest": "^7.0.0",
    "@types/yamljs": "^0.2.34",
    "dependency-cruiser": "^16.10.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "jiti": "^2.5.1",
    "lint-staged": "^16.0.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "semantic-release-preconfigured-conventional-commits": "^1.1.152",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.12",
    "typedoc-github-theme": "^0.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vite-tsconfig-paths": "^6.0.0",
    "vitest": "^4.0.0",
    "vitest-mock-extended": "^4.0.0"
  }
}
