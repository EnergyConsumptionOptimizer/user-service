{
  "name": "user-service",
  "engines": {
    "node": "24.18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "start": "node dist/src/server.js",
    "start:dev": "tsx watch --tsconfig tsconfig.json src/server.ts",
    "test": "vitest run && dependency-cruiser src --config .dependency-cruiser.js",
    "test:unit": "vitest run src/test/unit",
    "test:integration": "vitest run src/test/integration",
    "test:component": "vitest run src/test/component",
    "test:arch": "depcruise src --config .dependency-cruiser.js",
    "lint": "biome lint ./src ./test",
    "lint:fix": "biome check --write ./src ./test",
    "format": "biome format --write ./src ./test",
    "format:check": "biome format ./src ./test",
    "docs": "typedoc --tsconfig tsconfig.build.json --entryPointStrategy expand ./src --plugin typedoc-github-theme",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.33.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.220.0",
    "bcryptjs": "^3.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.0.0",
    "ms": "^2.1.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-opentelemetry-transport": "^4.0.0",
    "reflect-metadata": "^0.2.2",
    "uuid": "^14.0.0",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.3.0",
    "@types/supertest": "^7.0.0",
    "@types/yamljs": "^0.2.34",
    "dependency-cruiser": "^18.0.0",
    "jiti": "^2.5.1",
    "lint-staged": "^16.0.0",
    "mongodb-memory-server": "^11.0.1",
    "rimraf": "^6.0.1",
    "semantic-release-preconfigured-conventional-commits": "^1.1.152",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.12",
    "typedoc-github-theme": "^0.4.0",
    "typescript": "^6.0.0",
    "vite-tsconfig-paths": "^6.0.0",
    "vitest": "^4.0.0",
    "vitest-mock-extended": "^5.0.0"
  }
}
